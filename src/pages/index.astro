---
/**
 * Basado en el repositorio https://github.com/ttomczak3/Milky-Way
 */

import Layout from "../layouts/Layout.astro";
import Skills from "../components/Skills.astro";

import { ABOUT, INTERESTS } from "../consts/index.ts"
---

<Layout title="Eacuna" description="Portafolio">
  <!--
		Esto o una portada
	<div class="gif">
    <img width="300" height="259" alt="RaccoonSpaceGif" src="/space.webp" />
  </div>
	-->
  <h1>Edwin Acuña</h1>
  <span class="badge">Desarrollador Full-Stack</span>
  <h2>Sobre mi</h2>
    {
      ABOUT.map((paragraph) => (<p>{paragraph}</p>))
    }
  <div class="center">
    <a href="/works/" class="btn">Portafolio</a>
  </div>
  <h2>Habilidades</h2>
  <Skills />
  <h2>Intereses</h2>
  {
    INTERESTS.map((paragraph) => (<p>{paragraph}</p>))
  }
  </Layout>
